# Порт, на котором приложение будет доступно на хосте
APP_PORT=3000

# Секрет для подписи JWT — придумайте длинную случайную строку
JWT_SECRET=please-change-this-to-a-long-random-string

# PIN по умолчанию для пользователей "Муж" и "Жена" при первом запуске
DEFAULT_PIN=1234

# Токен подписки Claude Max. Получить локально командой:
#   claude setup-token
# и вставить сюда. Без него разбор чеков/сообщений через Claude работать не будет,
# но всё остальное (ручной ввод, коммуналка, статистика) — да.
CLAUDE_CODE_OAUTH_TOKEN=

# Модель Claude (по умолчанию Opus)
CLAUDE_MODEL=claude-opus-4-8
